@page "/search"
@inject HttpClient Http

<h3>SearchPage</h3>

<div>
    <input @bind="searchInput" placeholder="Indtast søgeord..." />
    <button @onclick="SearchStartsWith">Starter med</button>
    <button @onclick="SearchContains">Indeholder</button>
</div>

@if (searchMessage != null)
{
    <p><em>@searchMessage</em></p>
}

@if (filteredWords != null)
{
    <ul>
        @foreach (var w in filteredWords.Take(visibleCount))
        {
            <li>@w</li>
        }
    </ul>

    @if (visibleCount < filteredWords.Length)
    {
        <button @onclick="ShowMore">flere...</button>
    }
}
else
{
    <p>Venter på at ord bliver indlæst...</p>
}

@code {
    string[]? filteredWords;   // det aktuelle søgeresultat (eller de første 100 ved start)
    string[]? allWords;        // alle ord fra filen
    string searchInput = "";
    string? searchMessage;
    int visibleCount = 10;

    protected override void OnInitialized()
    {
        filteredWords = new string[0];
    }

    protected override async Task OnInitializedAsync()
    {
        allWords = await LoadAllWords();
        filteredWords = allWords.Take(100).ToArray();
    }

    private void SearchStartsWith()
    {
        if (allWords == null) return;

        filteredWords = allWords
            .Where(w => w.StartsWith(searchInput, StringComparison.OrdinalIgnoreCase))
            .ToArray();

        visibleCount = 10;
        searchMessage = $"Herunder er {filteredWords.Length} ord som starter med \"{searchInput}\"";
    }

    private void SearchContains()
    {
        if (allWords == null) return;

        filteredWords = allWords
            .Where(w => w.Contains(searchInput, StringComparison.OrdinalIgnoreCase))
            .ToArray();

        visibleCount = 10;
        searchMessage = $"Herunder er {filteredWords.Length} ord som indeholder \"{searchInput}\"";
    }

    private void ShowMore()
    {
        visibleCount += 10;
    }

    private async Task<string[]> LoadAllWords()
    {
        string content = await Http.GetStringAsync("sample-data/words.txt");
        return content.Split("\n");
    }
}
